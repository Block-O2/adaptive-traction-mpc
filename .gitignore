# Python cache and bytecode
__pycache__/
*.py[cod]
*.pyc
*$py.class
*.egg-info/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# Local/editor metadata
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*.tmp
*.temp
*.log

# Generated raw experiment outputs
results/logs/
results/debug/
results/tmp/
results/_archive/
results/**/logs/
results/**/*.gif
results/**/*.mp4
results/**/*.mov
results/**/*.avi
legacy/**/*.mp4

# Final reports, summary CSVs, and representative figures are intentionally tracked.
!results/**/*.md
!results/**/*.csv
!results/**/*.png
!docs/reports/
!docs/reports/*.md

# CAD / STEP model files
*.stp
*.step
third_party/mujoco_menagerie/
