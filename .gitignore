results/logs/
results/debug/
results/tmp/
results/archive/
results/reports/
results/**/*.csv
results/**/*.png
results/**/*.gif
results/**/*.mp4
legacy/**/*.mp4

# Curated Stage 1 outputs are intentionally tracked.
!results/stage1_spring2d/
!results/stage1_spring2d/**

# Curated documentation reports are intentionally tracked.
!docs/reports/
!docs/reports/*.md

