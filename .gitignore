# Python cache and bytecode
__pycache__/
*.py[cod]
*.pyc
*$py.class
*.egg-info/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# Local/editor metadata
.DS_Store
.idea/
.vscode/

